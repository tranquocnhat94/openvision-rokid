{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openvision.local/schemas/skill_manifest.schema.json",
  "title": "SkillManifest",
  "type": "object",
  "required": [
    "id",
    "name",
    "description",
    "tool_name",
    "input_schema",
    "result_schema",
    "latency_class",
    "local_first",
    "cloud_allowed",
    "cloud_behavior",
    "privacy_level",
    "media_requirements",
    "display_capabilities",
    "memory_allowed",
    "hud_policy",
    "timeout_ms",
    "local_resources",
    "activation_phrases_vi",
    "acceptance_tests",
    "failure_modes"
  ],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string"},
    "version": {"type": "string"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "tool_name": {"type": "string"},
    "input_schema": {"type": "object"},
    "result_schema": {"type": "object"},
    "latency_class": {"type": "string", "enum": ["live", "interactive", "deep"]},
    "local_first": {"type": "boolean"},
    "cloud_allowed": {"type": "boolean"},
    "cloud_behavior": {"type": "string", "enum": ["local_only", "gateway_optional", "gateway_required"]},
    "privacy_level": {"type": "string", "enum": ["low", "medium", "high", "sensitive"]},
    "media_requirements": {
      "type": "object",
      "required": ["default_mode", "allowed_modes", "requires_camera", "requires_mic", "live_video_allowed"],
      "additionalProperties": false,
      "properties": {
        "default_mode": {"type": "string", "enum": ["none", "snapshot", "burst_clip", "live_video"]},
        "allowed_modes": {
          "type": "array",
          "items": {"type": "string", "enum": ["none", "snapshot", "burst_clip", "live_video"]}
        },
        "requires_camera": {"type": "boolean"},
        "requires_mic": {"type": "boolean"},
        "live_video_allowed": {"type": "boolean"}
      }
    },
    "display_capabilities": {"type": "array", "items": {"type": "string"}},
    "memory_allowed": {"type": "boolean"},
    "hud_policy": {"type": "string"},
    "timeout_ms": {"type": "integer", "minimum": 1},
    "local_resources": {"type": "array", "items": {"type": "string"}},
    "activation_phrases_vi": {"type": "array", "items": {"type": "string"}},
    "activation_phrases_en": {"type": "array", "items": {"type": "string"}},
    "acceptance_tests": {"type": "array", "items": {"type": "string"}},
    "failure_modes": {"type": "array", "items": {"type": "string"}}
  }
}
