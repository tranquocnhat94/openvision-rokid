{
  "id": "openvision.skill.analyze_selected_target",
  "version": "0.1.0",
  "name": "analyze_selected_target",
  "description": "Answer a follow-up question about the currently selected target.",
  "tool_name": "analyze_selected_target",
  "latency_class": "interactive",
  "local_first": true,
  "cloud_allowed": true,
  "cloud_behavior": "gateway_required",
  "privacy_level": "medium",
  "media_requirements": {
    "default_mode": "snapshot",
    "allowed_modes": ["snapshot", "burst_clip"],
    "requires_camera": true,
    "requires_mic": false,
    "live_video_allowed": false
  },
  "display_capabilities": ["text_hud", "thumbnail_card", "target_hint"],
  "memory_allowed": false,
  "hud_policy": "answer_strip",
  "timeout_ms": 5000,
  "local_resources": ["selected_target_state", "crop_store"],
  "activation_phrases_vi": ["người đó", "mục tiêu đó", "xem kỹ người này"],
  "activation_phrases_en": ["that target", "analyze selected target"],
  "input_schema": {
    "type": "object",
    "properties": {
      "question": {"type": "string", "minLength": 1},
      "include_recent_crops": {"type": "boolean"}
    },
    "required": ["question"],
    "additionalProperties": false
  },
  "result_schema": {
    "type": "object",
    "properties": {
      "answer": {"type": "string"},
      "target_id": {"type": "string"},
      "evidence": {"type": "array", "items": {"type": "string"}}
    },
    "required": ["answer"],
    "additionalProperties": false
  },
  "acceptance_tests": ["requires selected target", "uses crop evidence before cloud"],
  "failure_modes": ["no selected target", "crop evidence missing", "cloud unavailable"]
}
