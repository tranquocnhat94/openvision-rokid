{
  "id": "openvision.skill.count_people",
  "version": "0.1.0",
  "name": "count_people",
  "description": "Count visible people using Jetson-owned detections/tracks. Use only for explicit person-count questions, not open-ended scene questions such as \"đang có gì trước mặt tôi\".",
  "tool_name": "count_people",
  "latency_class": "live",
  "local_first": true,
  "cloud_allowed": false,
  "cloud_behavior": "local_only",
  "privacy_level": "low",
  "media_requirements": {
    "default_mode": "none",
    "allowed_modes": ["none", "snapshot", "live_video"],
    "requires_camera": false,
    "requires_mic": false,
    "live_video_allowed": true
  },
  "display_capabilities": ["text_hud"],
  "memory_allowed": false,
  "hud_policy": "answer_strip",
  "timeout_ms": 1500,
  "local_resources": ["perception_graph", "yolo26_rokid_adapter"],
  "activation_phrases_vi": ["có bao nhiêu người", "đếm người", "phía trước có mấy người"],
  "activation_phrases_en": ["count people", "how many people"],
  "input_schema": {
    "type": "object",
    "properties": {
      "frame_window_ms": {"type": "integer", "minimum": 100, "maximum": 5000},
      "min_confidence": {"type": "number", "minimum": 0, "maximum": 1}
    },
    "required": [],
    "additionalProperties": false
  },
  "result_schema": {
    "type": "object",
    "properties": {
      "count": {"type": "integer", "minimum": 0},
      "confidence": {"type": "number", "minimum": 0, "maximum": 1},
      "evidence": {"type": "array", "items": {"type": "string"}}
    },
    "required": ["count", "confidence"],
    "additionalProperties": false
  },
  "acceptance_tests": ["returns count from latest perception snapshot", "does not call cloud"],
  "failure_modes": ["no perception snapshot", "detector offline"]
}
