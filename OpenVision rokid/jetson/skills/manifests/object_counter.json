{
  "id": "openvision.skill.object_counter",
  "version": "0.1.0",
  "name": "object_counter",
  "description": "Count visible non-person objects or repeated items from Jetson-owned frame evidence. Use for questions like \"có bao nhiêu hạt\", \"đếm mấy cái\", \"bao nhiêu ô\", or \"có mấy ly\".",
  "tool_name": "object_counter",
  "latency_class": "interactive",
  "local_first": true,
  "cloud_allowed": true,
  "cloud_behavior": "gateway_optional",
  "privacy_level": "medium",
  "media_requirements": {
    "default_mode": "snapshot",
    "allowed_modes": ["snapshot", "burst_clip"],
    "requires_camera": true,
    "requires_mic": false,
    "live_video_allowed": false
  },
  "display_capabilities": ["text_hud", "thumbnail_card"],
  "memory_allowed": false,
  "hud_policy": "answer_strip",
  "timeout_ms": 9000,
  "local_resources": ["frame_bus", "perception_graph"],
  "activation_phrases_vi": [
    "có bao nhiêu cái",
    "có mấy cái",
    "đếm đồ vật",
    "đếm mấy cái",
    "bao nhiêu hạt",
    "có mấy hạt",
    "bao nhiêu ô"
  ],
  "activation_phrases_en": ["count objects", "how many objects", "how many items"],
  "input_schema": {
    "type": "object",
    "properties": {
      "question": {"type": "string", "minLength": 1},
      "target": {"type": "string"},
      "approximate_ok": {"type": "boolean"}
    },
    "required": ["question"],
    "additionalProperties": false
  },
  "result_schema": {
    "type": "object",
    "properties": {
      "answer": {"type": "string"},
      "count": {"type": ["integer", "null"], "minimum": 0},
      "target": {"type": ["string", "null"]},
      "evidence": {"type": "array", "items": {"type": "string"}}
    },
    "required": ["answer"],
    "additionalProperties": false
  },
  "acceptance_tests": [
    "requests fresh snapshot before counting when no current media exists",
    "uses local perception counts when matching detections exist",
    "uses cloud gateway for preview-backed arbitrary visual counts"
  ],
  "failure_modes": ["no frame evidence", "object too small/occluded", "cloud unavailable when needed"]
}
