[Unit]
Description=OpenVision Rokid v2 Jetson Agent
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=jay
WorkingDirectory=/home/jay/openvision-rokid-v2/jetson/agent
Environment=OPENVISION_ENV=jetson
Environment=PYTHONDONTWRITEBYTECODE=1
Environment=OPENVISION_REALTIME_MODEL=gpt-realtime-mini
Environment=OPENVISION_REALTIME_MAX_OUTPUT_TOKENS=192
Environment=OPENVISION_REALTIME_VOICE_OUTPUT_ENABLED=0
Environment=OPENVISION_RV101_REALTIME_RECONNECT_GRACE_S=90
Environment=OPENVISION_REALTIME_AUDIO_GATE_MODE=monitor_only
Environment=OPENVISION_CLOUD_VERIFY_ENABLED=0
Environment=OPENVISION_CLOUD_VERIFY_MODEL=gpt-4.1-mini
Environment=OPENVISION_CLOUD_VERIFY_IMAGE_DETAIL=low
Environment=OPENVISION_CLOUD_VERIFY_TIMEOUT_S=8
Environment=OPENVISION_CLOUD_VERIFY_MAX_OUTPUT_TOKENS=160
Environment=OPENVISION_DEBUG_STT_ENABLED=0
Environment=OPENVISION_DEBUG_STT_LANGUAGE=vi
Environment=OPENVISION_DEBUG_STT_PROFILE=v2_debug_sentence
Environment=OPENVISION_DEBUG_STT_BEAM_SIZE=5
Environment=OPENVISION_DEBUG_STT_VAD_FILTER=1
Environment=OPENVISION_DEBUG_STT_MIN_AUDIO_MS=800
Environment=OPENVISION_DEBUG_STT_MAX_AUDIO_MS=12000
Environment="OPENVISION_DEBUG_STT_HOTWORDS=áo vàng, áo xanh, đếm người, tìm người, nghe được không"
Environment=OPENAI_API_KEY_FILE=/home/jay/openvision-rokid-v2/ops/secrets/openai_api_key
Environment=OPENVISION_RV101_TCP_INGEST=1
Environment=OPENVISION_RV101_BIND_HOST=0.0.0.0
Environment=OPENVISION_RV101_ADVERTISED_HOST=
Environment=OPENVISION_RV101_VIDEO_PORT=8770
Environment=OPENVISION_RV101_AUDIO_PORT=8771
Environment=OPENVISION_RV101_H264_PREVIEW=1
Environment=OPENVISION_RV101_H264_PREVIEW_EVERY_N_FRAMES=1
Environment=OPENVISION_RV101_H264_PREVIEW_MIN_INTERVAL_MS=66
Environment=OPENVISION_RV101_H264_PREVIEW_MAX_WIDTH=640
Environment=OPENVISION_RV101_H264_PREVIEW_JPEG_QUALITY=72
Environment=OPENVISION_RV101_H264_PREVIEW_QUEUE_SIZE=16
Environment=OPENVISION_RV101_H264_PREVIEW_DECODE_EVERY_SAMPLE=1
EnvironmentFile=-/home/jay/openvision-rokid-v2/ops/openvision.env
ExecStart=/home/jay/openvision-rokid-v2/.venv/bin/python -m uvicorn openvision_jetson.fastapi_app:app --host 0.0.0.0 --port 8765 --timeout-graceful-shutdown 3 --no-access-log
Restart=on-failure
RestartSec=2
TimeoutStopSec=8

[Install]
WantedBy=multi-user.target
