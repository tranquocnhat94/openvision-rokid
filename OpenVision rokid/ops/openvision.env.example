OPENVISION_ENV=jetson
OPENVISION_REALTIME_MODEL=gpt-realtime-mini
OPENVISION_REALTIME_MAX_OUTPUT_TOKENS=192
OPENVISION_REALTIME_VOICE_OUTPUT_ENABLED=0
OPENVISION_RV101_REALTIME_RECONNECT_GRACE_S=90
# Product default: Jetson only monitors audio metrics; Cloud Realtime server_vad
# owns turn detection/intent so natural Vietnamese phrasing is not clipped.
# Set suppress_idle_noise only for explicit cost experiments after voice QA passes.
OPENVISION_REALTIME_AUDIO_GATE_MODE=monitor_only

# Optional visual verifier behind CloudGateway. Leave disabled until you want
# captured previews/crops to be sent through typed OpenAI Responses vision.
OPENVISION_CLOUD_VERIFY_ENABLED=0
OPENVISION_CLOUD_VERIFY_MODEL=gpt-4.1-mini
OPENVISION_CLOUD_VERIFY_IMAGE_DETAIL=low
OPENVISION_CLOUD_VERIFY_TIMEOUT_S=8
OPENVISION_CLOUD_VERIFY_MAX_OUTPUT_TOKENS=160

# Debug-only Vietnamese STT sidecar. This does not route commands and does not
# use OpenAI transcription; it only shows completed spoken turns in Ops Console.
OPENVISION_DEBUG_STT_ENABLED=0
OPENVISION_DEBUG_STT_TRANSCRIBE_URL=http://MINI_PC_HOST:9460/inference
OPENVISION_DEBUG_STT_HEALTH_URL=http://MINI_PC_HOST:9460/health
OPENVISION_DEBUG_STT_WARM_URL=http://MINI_PC_HOST:9460/warm
OPENVISION_DEBUG_STT_AUTH_TOKEN_FILE=/home/jay/openvision-rokid-v2/ops/secrets/debug_stt_token
OPENVISION_DEBUG_STT_LANGUAGE=vi
OPENVISION_DEBUG_STT_PROFILE=v2_debug_sentence
OPENVISION_DEBUG_STT_BEAM_SIZE=5
OPENVISION_DEBUG_STT_VAD_FILTER=1
OPENVISION_DEBUG_STT_MIN_AUDIO_MS=800
OPENVISION_DEBUG_STT_MAX_AUDIO_MS=12000
OPENVISION_DEBUG_STT_HOTWORDS="áo vàng, áo xanh, đếm người, tìm người, nghe được không"

# Prefer a restricted Jetson-only key file. Do not commit real secrets.
OPENAI_API_KEY_FILE=/home/jay/openvision-rokid-v2/ops/secrets/openai_api_key
# Fallback env key exists for lab-only manual runs, but do not write it here.

# v2 YOLO26 must use a Rokid-specific runtime/path. Do not point this at the
# existing Ring / security runtime process.
OPENVISION_YOLO26_MODE=disabled
# OPENVISION_YOLO26_MODE=external_snapshot
# OPENVISION_YOLO26_MODE=external_stream
OPENVISION_YOLO26_ENGINE_PATH=/home/jay/openvision-rokid-v2/runtime/yolo26/openvision_yolo26.engine
OPENVISION_YOLO26_LABELS_PATH=/home/jay/openvision-rokid-v2/runtime/yolo26/yolo26_labels.txt
# External snapshot/stream sources should identify a separate Rokid/OpenVision
# runtime, for example `rokid_yolo26_external` or `openvision_iphone_yolo26`.
# Ring/security sources are rejected.
OPENVISION_YOLO26_MIN_CONFIDENCE=0.25
OPENVISION_YOLO26_STABILIZER_ENABLED=1
OPENVISION_YOLO26_STABLE_MIN_CONFIDENCE=0.35
OPENVISION_YOLO26_STABLE_INSTANT_CONFIDENCE=0.72
OPENVISION_YOLO26_STABLE_NMS_IOU=0.45
OPENVISION_YOLO26_STABLE_MATCH_IOU=0.30
OPENVISION_YOLO26_STABLE_SMOOTHING_ALPHA=0.45
OPENVISION_YOLO26_STABLE_HOLD_MS=500
OPENVISION_YOLO26_STABLE_MIN_HITS=2
OPENVISION_YOLO26_STABLE_MAX_DETECTIONS=40
OPENVISION_YOLO26_STABLE_DROP_MISSING_CONFIDENCE=1
OPENVISION_YOLO26_STABLE_DROP_UNCLASSIFIED=1
# Empty, "*" or "all" allows all classes. Default product path keeps this
# restricted so noisy generic DeepStream boxes do not reach preview/HUD.
# OPENVISION_YOLO26_STABLE_CLASS_ALLOWLIST=person,car,truck,bus,motorcycle,bicycle,backpack,bag,laptop,cell phone,bottle,chair
OPENVISION_RUNTIME_DIR=/home/jay/openvision-rokid-v2/runtime

# Product-path OpenVision/RV101 YOLO26 detector worker using NVIDIA DeepStream.
# DeepStream is a detector metadata feed; product bbox authority is the
# Jetson-side YOLO26 stabilizer/perception graph, not DeepStream OSD drawing.
# The old preview-polling worker is removed from the product tree to keep the
# runtime clean.
# It is a separate OpenVision runtime: own RTSP relay port, generated configs,
# MQTT topic prefix, status file, and DeepStream process. Do not point it at
# Ring / security runtime paths.
OPENVISION_DEEPSTREAM_YOLO26_WORKER_ENABLED=0
OPENVISION_DEEPSTREAM_YOLO26_JETSON_URL=http://127.0.0.1:8765
OPENVISION_DEEPSTREAM_YOLO26_SOURCE=openvision_rv101_yolo26_deepstream
OPENVISION_DEEPSTREAM_APP_BIN=/usr/bin/deepstream-app
OPENVISION_MOSQUITTO_SUB_BIN=/usr/bin/mosquitto_sub
OPENVISION_DEEPSTREAM_YOLO26_ONNX_PATH=/home/jay/DeepStream-Yolo/yolo26s.onnx
OPENVISION_DEEPSTREAM_YOLO26_ENGINE_PATH=/home/jay/openvision-rokid-v2/runtime/yolo26/openvision_yolo26.engine
OPENVISION_DEEPSTREAM_YOLO26_CUSTOM_LIB_PATH=/home/jay/DeepStream-Yolo/nvdsinfer_custom_impl_Yolo/libnvdsinfer_custom_impl_Yolo.so
OPENVISION_DEEPSTREAM_YOLO26_LABELS_PATH=/home/jay/openvision-rokid-v2/runtime/yolo26/yolo26_labels.txt
OPENVISION_DEEPSTREAM_YOLO26_MQTT_HOST=127.0.0.1
OPENVISION_DEEPSTREAM_YOLO26_MQTT_PORT=1884
OPENVISION_DEEPSTREAM_YOLO26_RTSP_PORT=8785
OPENVISION_DEEPSTREAM_YOLO26_ANNOTATED_RTSP_ENABLED=1
OPENVISION_DEEPSTREAM_YOLO26_ANNOTATED_RTSP_PORT=8795
OPENVISION_DEEPSTREAM_YOLO26_ANNOTATED_UDP_PORT=5600
OPENVISION_DEEPSTREAM_YOLO26_ANNOTATED_BITRATE=2500000
OPENVISION_DEEPSTREAM_YOLO26_STREAM_WIDTH=800
OPENVISION_DEEPSTREAM_YOLO26_STREAM_HEIGHT=600
OPENVISION_DEEPSTREAM_YOLO26_STREAM_FPS=15
OPENVISION_DEEPSTREAM_YOLO26_STREAMMUX_WIDTH=800
OPENVISION_DEEPSTREAM_YOLO26_STREAMMUX_HEIGHT=600
OPENVISION_DEEPSTREAM_YOLO26_MIN_CONFIDENCE=0.35
OPENVISION_DEEPSTREAM_YOLO26_INFER_INTERVAL=0
OPENVISION_DEEPSTREAM_YOLO26_TRACKER_ENABLED=1

# Optional separate local face identity worker for `target_finder` contact
# reminders such as "tìm Trâm". It runs only while an OpenVision target_finder
# live-video command is active and posts face bbox + embedding vectors to
# /api/adapters/face-identity/{session_id}/stream. It does not use Ring YOLO26.
OPENVISION_FACE_IDENTITY_MODE=external_stream
OPENVISION_FACE_IDENTITY_MIN_CONFIDENCE=0.75
OPENVISION_FACE_WORKER_ENABLED=0
OPENVISION_FACE_WORKER_JETSON_URL=http://127.0.0.1:8765
OPENVISION_FACE_WORKER_SOURCE=openvision_rokid_face_identity
OPENVISION_FACE_WORKER_BACKEND=opencv_sface
OPENVISION_FACE_WORKER_DETECTOR_MODEL=/home/jay/openvision-rokid-v2/runtime/face/face_detection_yunet_2023mar.onnx
OPENVISION_FACE_WORKER_RECOGNIZER_MODEL=/home/jay/openvision-rokid-v2/runtime/face/face_recognition_sface_2021dec.onnx
OPENVISION_FACE_WORKER_MIN_FACE_CONFIDENCE=0.75
OPENVISION_FACE_WORKER_MAX_FPS=2
OPENVISION_FACE_WORKER_POLL_INTERVAL_S=0.35
OPENVISION_FACE_WORKER_IDLE_POLL_INTERVAL_S=2.0
OPENVISION_FACE_WORKER_CROP_ENABLED=1
OPENVISION_FACE_WORKER_DETECTION_TARGET_SIZE=1280
OPENVISION_FACE_WORKER_ORIENTATION_FALLBACK=1
OPENVISION_FACE_WORKER_MIN_IDENTITY_FACE_SIDE_PX=56

# Local user-managed contact identity reminders for target_finder. Samples are
# stored in the OpenVision runtime DB and matched against face identity vectors
# or saved person/face crops.
OPENVISION_IDENTITY_DB_PATH=/home/jay/openvision-rokid-v2/runtime/identity/contacts.json
OPENVISION_IDENTITY_MIN_CONFIDENCE=0.86
OPENVISION_IDENTITY_SFACE_MIN_CONFIDENCE=0.45
OPENVISION_IDENTITY_MIN_FACE_SIDE_PX=56

# People Registry keeps user metadata for known people while Immich remains the
# photo/thumb owner. Put the real Immich API key in the file below; do not write
# it into this env example or git.
OPENVISION_PEOPLE_REGISTRY_DB_PATH=/home/jay/openvision-rokid-v2/runtime/people/people_registry.json
OPENVISION_IMMICH_BASE_URL=http://192.168.8.105:2283
OPENVISION_IMMICH_API_KEY_FILE=/home/jay/openvision-rokid-v2/ops/secrets/immich_api_key
OPENVISION_IMMICH_SYNC_TIMEOUT_S=8

# RV101 product media ingest. The app connects to /ws on the HTTP port, receives
# these TCP media ports in session_accept, then streams RVS1-framed H.264/PCM.
OPENVISION_RV101_TCP_INGEST=1
OPENVISION_RV101_BIND_HOST=0.0.0.0
# Leave blank for auto-detect, or set explicitly to the Jetson LAN IP.
OPENVISION_RV101_ADVERTISED_HOST=JETSON_LAN_IP
OPENVISION_RV101_VIDEO_PORT=8770
OPENVISION_RV101_AUDIO_PORT=8771

# Optional RV101 live H.264 preview decode. This is a Jetson Ops/perception
# preview, not the product stream sent by the glasses. Keep it throttled enough
# for Jetson CPU, but smooth enough to debug live camera motion.
OPENVISION_RV101_H264_PREVIEW=0
OPENVISION_RV101_H264_PREVIEW_EVERY_N_FRAMES=1
OPENVISION_RV101_H264_PREVIEW_MIN_INTERVAL_MS=66
OPENVISION_RV101_H264_PREVIEW_MAX_WIDTH=640
OPENVISION_RV101_H264_PREVIEW_JPEG_QUALITY=72
OPENVISION_RV101_H264_PREVIEW_QUEUE_SIZE=16
OPENVISION_RV101_H264_PREVIEW_DECODE_EVERY_SAMPLE=1

# Optional RV101 quality-review recordings on Jetson SSD. Keep this on NVMe so
# product review files do not grow on the Jetson eMMC/root filesystem. When
# enabled, Jetson writes raw H.264, raw mic WAV, annotated preview MJPEG, and
# finalized playable MP4 files so product sessions can be replayed/debugged.
OPENVISION_RV101_STREAM_RECORDING=0
OPENVISION_RV101_STREAM_RECORDING_DIR=/mnt/ssd/openvision-rokid-v2/recordings
OPENVISION_RV101_STREAM_RECORD_RAW_VIDEO=1
OPENVISION_RV101_STREAM_RECORD_RAW_AUDIO=1
OPENVISION_RV101_STREAM_RECORD_PROCESSED_PREVIEW=1
OPENVISION_RV101_STREAM_RECORD_PLAYABLE_VIDEO=1
OPENVISION_FFMPEG=/usr/bin/ffmpeg
OPENVISION_RV101_STREAM_RECORD_QUEUE_SIZE=256
OPENVISION_RV101_STREAM_RECORD_JPEG_QUALITY=82
