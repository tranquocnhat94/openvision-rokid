{
  "id": "openvision.skill.search_targets",
  "version": "0.1.0",
  "name": "search_targets",
  "description": "Find people/objects and return target candidates. Attribute queries such as shirt color, glasses, standing/sitting are unverified until a cloud attribute resolver confirms them.",
  "latency_class": "interactive",
  "local_first": true,
  "cloud_allowed": true,
  "privacy_level": "medium",
  "hud_policy": "thumbnail_strip",
  "timeout_ms": 6500,
  "local_resources": ["perception_graph", "crop_store"],
  "activation_phrases_vi": ["tìm người", "tìm áo xanh", "người mặc áo", "mục tiêu ở đâu"],
  "activation_phrases_en": ["find target", "find person", "person wearing"],
  "input_schema": {
    "type": "object",
    "properties": {
      "query": {"type": "string", "minLength": 1},
      "max_candidates": {"type": "integer", "minimum": 1, "maximum": 8}
    },
    "required": ["query"],
    "additionalProperties": false
  },
  "result_schema": {
    "type": "object",
    "properties": {
      "candidates": {"type": "array", "items": {"type": "object"}},
      "summary": {"type": "string"}
    },
    "required": ["candidates"],
    "additionalProperties": false
  },
  "acceptance_tests": ["returns local candidates", "marks attribute matches unverified before cloud resolver"],
  "failure_modes": ["no perception snapshot", "no candidate crop", "cloud resolver unavailable"]
}
